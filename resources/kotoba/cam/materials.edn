;; CAM material presets — density (g/cm^3) and Brinell hardness (HB).
;; Ported verbatim from kami-cam (Rust) `CamMaterial::{aluminum_6061, steel_1045,
;; titanium_ti6al4v, abs_plastic, wood_oak}`.
;;
;; This file is the canonical source of the preset table. It is not loaded at
;; runtime by the domain namespaces (kotoba.cam.stock keeps a literal copy so
;; the .cljc stays free of file IO and portable to cljs/wasm) — instead
;; test/kotoba/cam/materials_edn_test.clj asserts the embedded literal and
;; this file never drift apart.
{:aluminum-6061    {:name "Aluminum 6061-T6"    :density 2.70 :hardness 95.0}
 :steel-1045       {:name "Steel 1045"          :density 7.87 :hardness 163.0}
 :titanium-ti6al4v {:name "Titanium Ti-6Al-4V"  :density 4.43 :hardness 334.0}
 :abs-plastic      {:name "ABS Plastic"         :density 1.04 :hardness 10.0}
 :wood-oak         {:name "Oak (Red)"           :density 0.66 :hardness 6.0}}
